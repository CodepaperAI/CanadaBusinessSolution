# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Resend — transactional email (https://resend.com/api-keys)
RESEND_API_KEY=

# Sender address (must be on a domain verified in Resend)
CONTACT_FROM_EMAIL=Info@canadabusinesssolutions.ca

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=Info@canadabusinesssolutions.ca

# UpliftAI — automatic blog publishing
# Get the key from your UpliftAI dashboard
UPLIFT_API_KEY=
UPLIFT_API_URL=https://seotoolstaging.site/api/public/v1/blogs
